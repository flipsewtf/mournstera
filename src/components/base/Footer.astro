---
import { MusicIcon } from '@lucide/astro';
---

<footer>
    <div class="footer-inner">
        <nav class="footer-links" aria-label="Footer">
            <h2 class="sr-only">Social</h2>
            <ul>
                <li>
                    <a
                        href="https://bsky.app/profile/mournstera.wtf"
                        target="_blank"
                        rel="me noopener noreferrer">
                        Bluesky
                    </a>
                </li>

                <li>
                    <a
                        href="https://www.instagram.com/mournstera"
                        target="_blank"
                        rel="me noopener noreferrer">
                        Instagram
                    </a>
                </li>

                <li>
                    <a
                        href="https://mournstera.tumblr.com/"
                        target="_blank"
                        rel="me noopener noreferrer">
                        Tumblr
                    </a>
                </li>

                <li>
                    <em> Mastodon </em>
                </li>
            </ul>

            <h2 class="sr-only">Site</h2>
            <ul>
                <li><a href="/colophon/">Colophon</a></li>

                <li>
                    <a
                        href="https://github.com/flipsewtf"
                        target="_blank"
                        rel="me noopener noreferrer">
                        GitHub
                    </a>
                </li>

                <li><a href="/webrings/">Webrings</a></li>

                <li>
                    <a
                        class="rss desktop"
                        href="/rss.xml"
                        target="_blank"
                        rel="noopener noreferrer"
                        aria-label="Subscribe via RSS">
                        RSS
                    </a>
                </li>
            </ul>
        </nav>

        <div class="listened">
            <a
                class="track"
                href="https://listenbrainz.org/user/flipse"
                aria-label="See my latest scrobbled songs on my ListenBrainz profile (opens in new tab)"
                target="_blank"
                rel="noopener noreferrer">Loading last played track…</a
            >
            <MusicIcon />
        </div>
    </div>
</footer>

<style>
    a {
        color: var(--text);
    }
    a:hover {
        color: var(--accent-hover);
        text-decoration-color: var(--accent);
    }

    footer {
        background-color: var(--bg-warm);
        width: 100%;
        padding-block: var(--space-9);
        display: block;

        background-size: 100% var(--px1);
        background-repeat: no-repeat;
        background-position: top;
        background-image: repeating-linear-gradient(
            to right,
            var(--border) 0 4px,
            transparent 4px 6px
        );
    }

    .footer-inner {
        display: flex;
        gap: var(--space-4);
        justify-content: space-between;
        align-items: flex-start;
        flex-wrap: wrap;
        width: 100%;
        max-width: var(--layout--width);
        margin-inline: auto;
        padding-inline: var(--layout--padding);
    }

    nav.footer-links {
        display: flex;
        justify-items: start;
        gap: 0 var(--space-3);
    }

    nav.footer-links ul {
        display: flex;
        justify-items: start;
        gap: var(--space-1);
        flex-direction: column;
    }
    nav.footer-links a {
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    .listened {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: var(--px8);
        font-size: var(--text--xs);

        svg {
            width: 1.125rem;
            height: 1.125rem;
            color: var(--accent);
        }
    }
    a.track {
        line-height: var(--line-height--heading);
        text-align: right;
        font-family: var(--font--mono);
        max-width: 23rem;
        font-size: var(--text--xs);
        color: var(--text-alt);
        white-space: pre;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    @keyframes bop {
        from,
        to {
            transform: scale(1, 1);
        }
        25% {
            transform: scale(0.9, 1.1);
        }
        50% {
            transform: scale(1.1, 0.9);
        }
        75% {
            transform: scale(0.95, 1.05);
        }
    }
    @keyframes bop {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-1.5px);
        }
    }

    .listened :global(svg) {
        animation: bop 0.8s ease-in-out infinite;
        animation: bop 1.3s var(--transition--snappy) infinite;
    }
</style>
<script src="/scripts/scrobble.js" defer></script>
