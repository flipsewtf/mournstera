---
const { href, label } = Astro.props;
---

<!-- prettier-ignore -->
<a href={href} class="external-link page-link" target="_blank" rel="noopener noreferrer"><span class="external-link-text">{label}</span><svg xmlns="http://www.w3.org/2000/svg" aria-hidden="true" viewBox="0 0 24 24"><path d="M12 6h-6a2 2 0 0 0 -2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-6" /><path d="M11 13l9 -9" /><path d="M15 4h5v5" /></svg><span class="sr-only">(opens in a new tab)</span></a>

<style>
    svg {
        stroke: var(--accent-hover);
        height: 1.25em;
        width: 1.25em;
        vertical-align: text-bottom;
        margin-left: 0.125em;
    }
</style>
