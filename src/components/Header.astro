</header>

<style>
    a {
        color: var(--text-alt);
        text-decoration: none;
    }
    a:hover {
        color: var(--accent);
    }

    header.top {
        width: 100%;
        position: sticky;
        top: 0;
        z-index: 200;
        background-color: var(--bg-trans);
        backdrop-filter: blur(16px);
        height: var(--layout--header);
    }

    .header-inner {
        width: 100%;
        max-width: var(--layout--width);
        padding-inline: var(--layout--padding);
        margin: 0 auto;
        display: flex;
        gap: var(--space-2);
        justify-content: space-between;
        align-items: center;
        padding-block: var(--space-2);
    }
    .header-nav-wrap {
        display: flex;
        gap: var(--space-2);
        align-items: center;
    }
    a.monstera {
        position: relative;
        display: inline-flex;
    }
    a.monstera svg {
        width: 3.75rem;
        height: 3.75rem;
        fill: currentColor;
        stroke: transparent;
        stroke-width: 0;
        transform: rotateY(180deg) rotateX(180deg);
        transform-origin: center;
        transform-box: fill-box;
        shape-rendering: geometricPrecision;
    }
    @media (min-width: 48rem) {
        a.monstera svg {
            width: 4rem;
            height: 4rem;
        }
    }
</style>
<script src="/scripts/nav.js" defer></script>
