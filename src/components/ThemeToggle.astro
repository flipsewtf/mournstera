---
// ThemeToggle.astro
import { MoonIcon, SunMediumIcon } from '@lucide/astro';
---

<button
    class="theme-toggle"
    type="button"
    data-tooltip="Toggle theme"
    aria-label="Toggle theme"
    aria-pressed="false">
    <SunMediumIcon class="sun" />
    <MoonIcon class="moon" />
</button>

<style>
    button.theme-toggle {
        color: var(--text-alt);
        display: inline-flex;
        position: relative;
        align-items: center;
        justify-content: center;
        width: calc(var(--svg-size) + var(--px8) * 2);
        height: calc(var(--svg-size) + var(--px8) * 2);
        transition: color var(--transition--smooth);
        border-radius: var(--radius--full);
        border: var(--px1) solid var(--border);
        background-color: var(--bg-alt);
        backdrop-filter: blur(10px);
    }

    button.theme-toggle:hover {
        color: var(--accent);
    }
    button.theme-toggle[data-tooltip]::after {
        bottom: auto;
        top: calc(100% + var(--space-3));
    }

    .sun,
    .moon {
        position: absolute;
        transform-origin: center;
        transition: none;
        transform-box: fill-box;
        width: calc(var(--svg-size) - var(--px2));
        height: calc(var(--svg-size) - var(--px2));
    }

    @media (prefers-reduced-motion: no-preference) {
        html[data-ready='true'] .sun,
        html[data-ready='true'] .moon {
            transition:
                opacity 0.2s ease,
                transform 0.3s cubic-bezier(0.8, -0.5, 0.2, 1.4);
        }
    }

    /* Light mode */
    .sun {
        opacity: 1;
        transform: rotate(0deg) scale(1);
    }

    .moon {
        opacity: 0;
        transform: rotate(-180deg) scale(0.5);
    }

    :global([data-theme='dark']) .sun {
        opacity: 0;
        transform: rotate(180deg) scale(0.5);
    }

    :global([data-theme='dark']) .moon {
        opacity: 1;
        transform: rotate(0deg) scale(1);
    }

    :global(html.no-transition *:not(.theme-toggle *)) {
        transition: none !important;
        animation: none !important;
    }
    /* DESKTOP*/
    @media (min-width: 48rem) {
        button.theme-toggle {
            width: calc(var(--svg-size) + var(--space-2) * 2);
        }
    }
</style>
<script src="/scripts/theme-toggle.js" is:inline></script>
