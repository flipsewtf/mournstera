---
// garden.astro
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import GardenSidebar from '@/components/garden/GardenSidebar.astro';
import GardenPost from '@/components/garden/GardenPost.astro';
import { gardenMeta } from '@/assets/data/garden-meta';
import '@/assets/styles/garden.css';
import { SproutIcon, ShovelIcon, BrainIcon } from '@lucide/astro';

const allGarden = (await getCollection('garden')).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const tags = [
    'all',
    ...Array.from(new Set(allGarden.map((p) => p.data.tags).flat())).sort((a, b) =>
        a.localeCompare(b, 'en', { sensitivity: 'base' }),
    ),
];

const postsByKind = Object.groupBy(allGarden, (post) => post.data.kind);

const kindIcons = {
    musings: BrainIcon,
    notes: ShovelIcon,
    seedlings: SproutIcon,
};
---

<BaseLayout pageTitle={gardenMeta.title} pageDescription={gardenMeta.description}>
    <GardenSidebar slot="sidebar" tags={tags} currentTag="all" />

    {
        Object.entries(postsByKind).map(([kind, posts]) => {
            const Icon = kindIcons[kind as keyof typeof kindIcons];

            return (
                <section class="garden-kind-group">
                    <h3 class="garden-heading">
                        {Icon && <Icon />}
                        {kind}
                    </h3>

                    <ul class="garden-list">
                        {posts.map((post) => (
                            <GardenPost
                                url={`/garden/${post.id}/`}
                                title={post.data.title}
                                pubDate={post.data.pubDate}
                                tags={post.data.tags}
                            />
                        ))}
                    </ul>
                </section>
            );
        })
    }
</BaseLayout>
