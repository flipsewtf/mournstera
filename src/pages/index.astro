---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = ``;
---

<BaseLayout isPost={true} pageTitle={pageTitle} mainClass="homepage">
    <section class="hero">
        <h1>Hello, my name is Flipse</h1>

        <h2>
            I am a <span class="sparkle-wrap">
                tinkerer
                <span class="sparkles" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                        <defs>
                            <linearGradient
                                id="sparkleGradient-1"
                                x1="0%"
                                y1="0%"
                                x2="100%"
                                y2="100%">
                                <stop offset="0%" stop-color="#ffe986"></stop>
                                <stop offset="100%" stop-color="#ef7808"></stop>
                            </linearGradient>
                        </defs>

                        <path
                            d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"
                            fill="url(#sparkleGradient-1)"></path>
                    </svg>

                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                        <defs>
                            <linearGradient
                                id="sparkleGradient-2"
                                x1="0%"
                                y1="0%"
                                x2="100%"
                                y2="100%">
                                <stop offset="0%" stop-color="#ffe986"></stop>
                                <stop offset="100%" stop-color="#ef7808"></stop>
                            </linearGradient>
                        </defs>

                        <path
                            d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"
                            fill="url(#sparkleGradient-2)"></path>
                    </svg>

                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                        <defs>
                            <linearGradient
                                id="sparkleGradient-3"
                                x1="0%"
                                y1="0%"
                                x2="100%"
                                y2="100%">
                                <stop offset="0%" stop-color="#ffe986"></stop>
                                <stop offset="100%" stop-color="#ef7808"></stop>
                            </linearGradient>
                        </defs>

                        <path
                            d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"
                            fill="url(#sparkleGradient-3)"></path>
                    </svg>
                </span>
            </span>.
        </h2>

        <p>
            I worked on <a
                href="https://mournstera.tumblr.com/"
                target="_blank"
                rel="noopener noreferrer">Tumblr themes</a
            > for 15 years, but it was time to set sail elsewhere. I started my first blog in 2000 and
            now return to the old ship, with better code, of course.
        </p>

        <p>I'm not entirely sure what I'm doing or what this will be, and that's exciting.</p>
    </section>

    <style>
        :global(main.homepage) {
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        section.hero {
            max-width: var(--section-width);

            h1 {
                font-size: var(--text-md);
                font-family: var(--font-primary);
                text-transform: uppercase;
                letter-spacing: 0.05em;
                font-weight: 700;
                color: var(--text);
            }
            h2 {
                font-size: var(--h1);
                margin: var(--space-0) 0 var(--text-margin-md) 0;
            }
        }

        p a {
            font-weight: 500;
            text-decoration-color: var(--purple-acent);
        }
        p a:hover {
            text-decoration-color: var(--peach-border);
        }

        /*  --- sparkle */
        .sparkle-wrap {
            position: relative;
            display: inline-block;
            line-height: 1;
        }

        .sparkles {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none; /* hey don't block text */
        }

        .sparkles svg {
            position: absolute;
            width: 2rem;
            height: 2rem;
            transform: translate(-50%, -50%) scale(0);
            opacity: 0;
            top: calc(var(--y) * 1%);
            left: calc(var(--x) * 1%);
        }

        .sparkle-wrap svg path {
            stroke: transparent;
            stroke-width: 0;
        }

        .sparkles svg:nth-of-type(1) {
            --x: 15;
            --y: 0;
            --s: 1.15;
        }

        .sparkles svg:nth-of-type(2) {
            --x: 45;
            --y: 80;
            --s: 1;
        }

        .sparkles svg:nth-of-type(3) {
            --x: 90;
            --y: 30;
            --s: 0.75;
        }

        .sparkle-boop svg:nth-of-type(1) {
            animation: sparkle 0.95s 0s both;
        }
        .sparkle-boop svg:nth-of-type(2) {
            animation: sparkle 0.95s 0.15s both;
        }
        .sparkle-boop svg:nth-of-type(3) {
            animation: sparkle 0.95s 0.3s both;
        }

        @keyframes sparkle {
            0% {
                transform: translate(-50%, -50%) scale(0);
                opacity: 0;
            }
            50% {
                transform: translate(-50%, -50%) scale(var(--s, 1));
                opacity: 1;
            }
            100% {
                transform: translate(-50%, -50%) scale(0);
                opacity: 0;
            }
        }

        @media (prefers-reduced-motion: reduce) {
            .sparkles {
                display: none;
            }
        }
    </style>

    <script src="/scripts/sparkle.js" defer></script>
</BaseLayout>
